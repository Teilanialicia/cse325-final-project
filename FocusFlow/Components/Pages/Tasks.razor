@page "/tasks"
@using FocusFlow.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db

<h1 class="page-title">Task Management</h1>
<div class="panel">
    <div class="form-section">
        <input class="input" placeholder="Task Name" @bind="newTask.Title" />
        <input class="input" type="date" @bind="newTask.DueDate" />
        <select class="input" @bind="newTask.Priority">
            <option>Low</option>
            <option>Medium</option>
            <option>High</option>
        </select>
        <button class="btn-primary" @onclick="AddTask">
            + Add Task
        </button>
    </div>
</div>
<div class="list-section">
    @foreach (var task in tasks)
    {
        <div class="card-item @(task.IsCompleted ? "completed" : "")">
            <div class="card-main">
                <strong>@task.Title</strong>
                <div class="meta">
                    <span>@task.DueDate.ToShortDateString()</span>
                    <span class="priority @task.Priority.ToLower()">
                        @task.Priority
                    </span>
                </div>
            </div>
            <div class="card-actions">
                <input type="checkbox"
                       checked="@task.IsCompleted"
                       @onchange="async (e) => await HandleCheckboxChange(e, task)" />
                <button class="delete-btn"
                        @onclick="() => DeleteTask(task.Id)">
                    Delete
                </button>
            </div>
        </div>
    }
</div>

@code {

    private List<StudentTask> tasks = new();

    private StudentTask newTask = new()
    {
        DueDate = DateTime.UtcNow
    };

    protected override async Task OnInitializedAsync()
    {
        tasks = await Db.StudentTasks.ToListAsync();
    }

    private async Task HandleCheckboxChange(ChangeEventArgs e, StudentTask task)
    {
        task.IsCompleted = (bool)e.Value!;

        Db.StudentTasks.Update(task);

        await Db.SaveChangesAsync();
    }

    private async Task AddTask()
    {
        if (!string.IsNullOrWhiteSpace(newTask.Title))
        {
            newTask.DueDate = DateTime.SpecifyKind(
                newTask.DueDate,
                DateTimeKind.Utc);

            Db.StudentTasks.Add(new StudentTask
            {
                Title = newTask.Title,
                DueDate = newTask.DueDate,
                Priority = newTask.Priority,
                IsCompleted = false
            });

            await Db.SaveChangesAsync();
            tasks = await Db.StudentTasks.ToListAsync();
        }
    }

    private async Task UpdateTask(StudentTask task)
    {
        Db.StudentTasks.Update(task);
        await Db.SaveChangesAsync();
    }

    private async Task DeleteTask(int id)
    {
        var task = await Db.StudentTasks.FindAsync(id);

        if (task != null)
        {
            Db.StudentTasks.Remove(task);

            await Db.SaveChangesAsync();

            tasks = await Db.StudentTasks.ToListAsync();
        }
    }
}