@page "/"
@layout MainLayout

<PageTitle>FocusFlow</PageTitle>

<div class="dashboard-container">
    <div class="hero-section">
        <h1>Welcome to FocusFlow 🌱</h1>
        <p class="hero-text">
            Stay organized, manage your coursework, and build better study habits.
            Designed to help students reduce overwhelm and stay focused on what matters most.
        </p>
        <div class="hero-buttons">
            <a class="btn btn-primary btn-lg" href="/tasks">
                View Tasks
            </a>

            <a class="btn btn-outline-primary btn-lg" href="/courses">
                Manage Courses
            </a>
        </div>
    </div>

    <div class="quick-actions">
        <h2>Quick Actions</h2>
        <div class="actions-grid">
            <a href="/tasks" class="action-card">
                <h3>Tasks</h3>
                <p>Create, update, and complete assignments.</p>
            </a>

            <a href="/courses" class="action-card">
                <h3>Courses</h3>
                <p>Organize assignments by class.</p>
            </a>

            <a href="/pomodoro" class="action-card">
                <h3>Pomodoro</h3>
                <p>Stay focused with timed study sessions.</p>
            </a>
        </div>
    </div>

    <div class="features-section">
        <h2>Why FocusFlow?</h2>
        <div class="features-grid">
            <div class="feature-card">
                <h3>Stay Organized</h3>
                <p>
                    Keep all assignments, deadlines, and courses in one place.
                </p>
            </div>

            <div class="feature-card">
                <h3>Reduce Overwhelm</h3>
                <p>
                    Simple layouts and focused tools designed for students.
                </p>
            </div>

            <div class="feature-card">
                <h3>Build Better Habits</h3>
                <p>
                    Use Pomodoro sessions and progress tracking to stay consistent.
                </p>
            </div>
        </div>
    </div>
</div>