
@page "/"

<PageTitle>FocusFlow</PageTitle>

<div class="hero">
    <h1>FocusFlow</h1>
    <p>An ADHD-Friendly Student Planner</p>

    <div class="hero-buttons">
        <a class="btn-primary" href="/courses">Manage Courses</a>
        <a class="btn-secondary" href="/tasks">Manage Tasks</a>
    </div>
</div>

<div class="features-grid">
    <div class="feature-card">
        <h3>Organize Courses</h3>
        <p>Create courses and keep assignments separated by class.</p>
    </div>

    <div class="feature-card">
        <h3>Track Assignments</h3>
        <p>Manage deadlines, priorities, and completed work.</p>
    </div>

    <div class="feature-card">
        <h3>Stay Focused</h3>
        <p>Use the built-in Pomodoro timer to improve concentration.</p>
    </div>
</div>
