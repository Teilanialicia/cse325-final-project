@using FocusFlow.Services
@inject AuthService AuthService
@inject NavigationManager Nav
@implements IDisposable

<nav class="navbar">

    <div class="nav-container">

        <a class="navbar-brand" href="/">
            🌱 FocusFlow
        </a>

        <div class="nav-links">

            @if (AuthService.IsLoggedIn)
            {
                <div class="nav-links">
                    <NavLink class="nav-link" href="/courses">
                        Courses
                    </NavLink>

                    <NavLink class="nav-link" href="/tasks">
                        Tasks
                    </NavLink>

                    <NavLink class="nav-link" href="/pomodoro">
                        Focus Timer
                    </NavLink>
                </div>
            }

        </div>

        <div class="nav-actions">

            @if (AuthService.IsLoggedIn)
            {
                <span class="user-badge">
                    Hello @AuthService.CurrentUser?.Name
                </span>

                <button class="btn btn-primary" @onclick="Logout">
                    Logout
                </button>
            }
            else
            {
                <NavLink class="btn btn-outline-primary" href="/login">
                    Login
                </NavLink>

                <NavLink class="btn btn-primary" href="/register">
                    Register
                </NavLink>
            }

        </div>

    </div>

</nav>

@code
{
    private async Task Logout()
    {
        await AuthService.Logout();
        Nav.NavigateTo("/login", true);
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        AuthService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AuthService.OnChange -= StateHasChanged;
    }
}